		{"id":"c74e2b9f9fffe5aa","type":"file","file":"Sims4-Yootz-Story/spoilers/3.4-Distant Family.md","x":0,"y":-1240,"width":400,"height":400},
		{"id":"a26a83510ccdc5c0","type":"text","text":"The fanged toddlers grow up a bit","x":1465,"y":-1149,"width":400,"height":400},
		{"id":"2a51c1f4b892cd44","type":"file","file":"Sims4-Yootz-Story/spoilers/Ravenwood Mansion.md","x":1000,"y":-1149,"width":400,"height":400},
		{"id":"3307c3a84b857558","type":"file","file":"Sims4-Yootz-Story/spoilers/Strangerville.md","x":1000,"y":-680,"width":400,"height":400},
		{"id":"a19a4c638bb8afc8","type":"file","file":"Sims4-Yootz-Story/spoilers/In Nature.md","x":1000,"y":-211,"width":400,"height":400},
		{"id":"1ee8600d0e7dfc9b","type":"file","file":"Sims4-Yootz-Story/spoilers/Working Hard.md","x":1465,"y":-680,"width":400,"height":400},
		{"id":"f538df45f7ed1ecd","type":"file","file":"Sims4-Yootz-Story/spoilers/Brenda.md","x":1930,"y":-680,"width":400,"height":400},
		{"id":"c3a77aba77185d66","type":"file","file":"Sims4-Yootz-Story/spoilers/Whats Next.md","x":2395,"y":-680,"width":400,"height":400},
