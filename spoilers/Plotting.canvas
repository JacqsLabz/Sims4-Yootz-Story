		{"id":"ef428fefc6292227","type":"file","file":"Sims4-Yootz-Story/spoilers/Don checks on Sara.md","x":5650,"y":-211,"width":400,"height":400},
		{"id":"e28b78635be6e63c","type":"file","file":"Sims4-Yootz-Story/spoilers/Anger Mgmt Advice.md","x":8380,"y":-211,"width":400,"height":400},
		{"id":"d6f90b2755ef0a13","type":"text","text":"TEMPLATE","x":3325,"y":-1149,"width":400,"height":400},
