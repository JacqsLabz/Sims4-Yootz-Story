		{"id":"6e7995f24abda398","type":"file","file":"Sims4-Yootz-Story/plans/spoilers/Retracing steps.md","x":4720,"y":-211,"width":400,"height":400},
		{"id":"2fd66ad5eb2d808e","type":"file","file":"Sims4-Yootz-Story/plans/spoilers/Sensing Moonstone.md","x":4985,"y":-749,"width":400,"height":400},
		{"id":"6add5cd6ff6f2e85","type":"file","file":"Sims4-Yootz-Story/plans/spoilers/Fairy draining.md","x":3790,"y":1000,"width":400,"height":400},
		{"id":"473a3b97e8304605","type":"file","file":"Sims4-Yootz-Story/plans/spoilers/Crystal moon shape.md","x":2989,"y":1053,"width":400,"height":400},
		{"id":"300c2626ca18126a","type":"file","file":"Sims4-Yootz-Story/plans/spoilers/Draining schedule.md","x":4255,"y":1000,"width":400,"height":400},
