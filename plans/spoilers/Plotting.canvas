		{"id":"aa85f7eef8a89a47","type":"file","file":"Sims4-Yootz-Story/plans/spoilers/Werewolf.md","x":3790,"y":-211,"width":400,"height":400},
		{"id":"746de11932cb12be","type":"file","file":"Sims4-Yootz-Story/plans/spoilers/Cass Teen.md","x":1465,"y":-211,"width":400,"height":400},
